SUPABASE_URL=
SUPABASE_SERVICE_KEY=
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:8000/api/qb/callback
QB_ENVIRONMENT=sandbox
JWT_SECRET=
FRONTEND_URL=http://localhost:3000
# Comma-separated for multiple sites, e.g. https://app.vercel.app,https://preview.vercel.app
# If OPTIONS preflight returns 400, open the failed OPTIONS row → Response:
# Starlette sets body to e.g. "Disallowed CORS origin" (Origin must match FRONTEND_URL
# exactly, or set CORS_ORIGIN_REGEX for patterns like https://.*\.vercel\.app).
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
