# FundSteward4 (Supabase) — same project as frontend; service key is server-only.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=

# Browser origins allowed to call this API (comma-separated). Must include your Vercel production URL.
# Example: https://your-app.vercel.app,https://www.yourdomain.com
FRONTEND_URL=http://localhost:3000

# Optional: allow Vercel preview URLs (or adjust to your host pattern). Backend validates regex at startup.
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Used when signing JWTs or session helpers (set in Railway for production).
# JWT_SECRET=

# QuickBooks (when integrated) — redirect must match Intuit Developer app + FastAPI route.
# QB_CLIENT_ID=
# QB_CLIENT_SECRET=
# QB_REDIRECT_URI=http://localhost:8000/api/qb/callback
# QB_ENVIRONMENT=sandbox
