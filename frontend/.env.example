# Browser → API base (optional)
#
# Recommended (Vercel + Railway): leave this UNSET or empty. The app will request /api/... on the
# same host; next.config.mjs proxies to BACKEND_ORIGIN — no CORS configuration needed.
#
# Optional: set to http://localhost:8000 for local dev if you prefer the browser to call FastAPI
# directly (FastAPI CORS must allow http://localhost:3000).
NEXT_PUBLIC_API_URL=

# FastAPI public origin for Next.js rewrites only (omit NEXT_PUBLIC_ — not shipped to the client).
# Vercel example: https://your-service.up.railway.app
BACKEND_ORIGIN=http://localhost:8000

# Supabase project URL from: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public key from: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_ANON_KEY=
